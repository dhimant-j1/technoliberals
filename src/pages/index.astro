---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import ClaudePartnerSection from '../components/ClaudePartnerSection.astro';
import IndustriesSection from '../components/IndustriesSection.astro';
import ProofSection from '../components/ProofSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import EngagementModels from '../components/EngagementModels.astro';
import FinalCTA from '../components/FinalCTA.astro';
import ContactSection from '../components/ContactSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <TrustStrip />
    <ProblemSection />
    <ServicesSection />
    <ClaudePartnerSection />
    <IndustriesSection />
    <ProofSection />
    <ProcessSection />
    <EngagementModels />
    <FinalCTA />
    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
