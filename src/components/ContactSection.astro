---
const field =
  'w-full rounded-xl border border-line bg-white/[0.02] px-4 py-3 text-sm text-fg placeholder:text-muted-2 transition focus:border-accent/60 focus:bg-white/[0.04]';

const budgets = [
  'Not sure yet',
  'Under $10k',
  '$10k – $30k',
  '$30k – $75k',
  '$75k – $150k',
  '$150k+',
];

const timelines = [
  'As soon as possible',
  '1–3 months',
  '3–6 months',
  '6+ months',
  'Just exploring',
];

const contactPoints = [
  { label: 'Email', value: 'hello@technoliberals.com', href: 'mailto:hello@technoliberals.com' },
  // TODO: Replace with your real WhatsApp business number.
  { label: 'WhatsApp', value: '+255 000 000 000', href: 'https://wa.me/255000000000' },
  { label: 'Execution hubs', value: 'East Africa · India', href: null },
];
---

<section id="contact" class="section">
  <div class="shell">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-14">
      <!-- Intro + contact points -->
      <div>
        <p class="eyebrow mb-5">Contact</p>
        <h2 class="text-3xl leading-tight sm:text-4xl">Book a strategy call.</h2>
        <p class="mt-5 text-lg leading-relaxed text-muted">
          Tell us what you're trying to build. We'll come back with a point of view, a likely
          approach, and how we'd scope the first engagement.
        </p>

        <dl class="mt-9 space-y-4">
          {
            contactPoints.map((point) => (
              <div class="flex items-center justify-between gap-4 border-b border-line pb-4">
                <dt class="text-sm text-muted-2">{point.label}</dt>
                <dd class="text-sm font-medium text-fg">
                  {point.href ? (
                    <a href={point.href} class="rounded transition hover:text-accent-soft">
                      {point.value}
                    </a>
                  ) : (
                    point.value
                  )}
                </dd>
              </div>
            ))
          }
        </dl>

        <p class="mt-6 text-sm leading-relaxed text-muted-2">
          Prefer async? Send the messy workflow, transaction flow, or process and we'll review it
          before the call.
        </p>
      </div>

      <!-- Form -->
      <div class="card p-6 sm:p-8">
        <!--
          TODO: This form is frontend-only. To make it live, wire `handleSubmit`
          (see the <script> below) to one of:
            • An email service / form backend (Formspree, Web3Forms, Resend)
            • Your own API route or serverless function
            • A CRM intake (HubSpot, Pipedrive, Zoho) or a Slack/Email webhook
          On the server: validate inputs, protect against spam (honeypot + rate
          limit), then store the lead and/or trigger a notification.
        -->
        <form id="contact-form" novalidate class="grid gap-4 sm:grid-cols-2">
          <!-- Honeypot: hidden from users, catches naive bots. -->
          <div class="hidden" aria-hidden="true">
            <label>Leave this field empty<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
          </div>

          <div class="sm:col-span-1">
            <label for="name" class="mb-1.5 block text-sm font-medium text-fg">Name <span class="text-accent">*</span></label>
            <input id="name" name="name" type="text" required autocomplete="name" class={field} placeholder="Your name" />
          </div>

          <div class="sm:col-span-1">
            <label for="company" class="mb-1.5 block text-sm font-medium text-fg">Company</label>
            <input id="company" name="company" type="text" autocomplete="organization" class={field} placeholder="Company name" />
          </div>

          <div class="sm:col-span-1">
            <label for="email" class="mb-1.5 block text-sm font-medium text-fg">Email <span class="text-accent">*</span></label>
            <input id="email" name="email" type="email" required autocomplete="email" class={field} placeholder="you@company.com" />
          </div>

          <div class="sm:col-span-1">
            <label for="phone" class="mb-1.5 block text-sm font-medium text-fg">Phone / WhatsApp</label>
            <input id="phone" name="phone" type="tel" autocomplete="tel" class={field} placeholder="+255 …" />
          </div>

          <div class="sm:col-span-2">
            <label for="brief" class="mb-1.5 block text-sm font-medium text-fg">What are you trying to build? <span class="text-accent">*</span></label>
            <textarea id="brief" name="brief" required rows="4" class={field} placeholder="The workflow, transaction flow, product, or AI use case you have in mind."></textarea>
          </div>

          <div class="sm:col-span-1">
            <label for="budget" class="mb-1.5 block text-sm font-medium text-fg">Budget range</label>
            <select id="budget" name="budget" class={field}>
              <option value="" selected>Select a range</option>
              {budgets.map((b) => <option value={b}>{b}</option>)}
            </select>
          </div>

          <div class="sm:col-span-1">
            <label for="timeline" class="mb-1.5 block text-sm font-medium text-fg">Timeline</label>
            <select id="timeline" name="timeline" class={field}>
              <option value="" selected>Select a timeline</option>
              {timelines.map((t) => <option value={t}>{t}</option>)}
            </select>
          </div>

          <div class="sm:col-span-2 mt-2 flex flex-wrap items-center gap-4">
            <button type="submit" class="btn-primary">Book a Strategy Call</button>
            <p id="form-error" class="hidden text-sm text-accent-soft" role="alert"></p>
          </div>
        </form>

        <!-- Success state (revealed after submit) -->
        <div id="form-success" class="hidden" tabindex="-1">
          <div class="flex items-start gap-4">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-xl bg-gradient-to-br from-accent to-accent-2 text-ink">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" aria-hidden="true">
                <path d="m5 12 4.5 4.5L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
            <div>
              <h3 class="text-lg font-semibold text-fg">Thanks — your message is ready to send.</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">
                We've captured your details. Once the backend is connected this will reach our team
                directly; for now, you can also email
                <a href="mailto:hello@technoliberals.com" class="text-accent-soft hover:underline">hello@technoliberals.com</a>.
                We typically reply within one business day.
              </p>
              <button type="button" id="form-reset" class="btn-secondary mt-5">Send another message</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const resetBtn = document.getElementById('form-reset');

  function showError(message: string) {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    errorEl?.classList.add('hidden');

    // Honeypot — if filled, silently pretend success without doing anything.
    const honeypot = (form.elements.namedItem('company_website') as HTMLInputElement)?.value;

    // Native validation for required fields + email format.
    if (honeypot === '' && !form.checkValidity()) {
      form.reportValidity();
      showError('Please complete the required fields.');
      return;
    }

    // TODO: Replace this block with a real submission, e.g.:
    //   const data = Object.fromEntries(new FormData(form).entries());
    //   await fetch('/api/contact', { method: 'POST', body: JSON.stringify(data) });
    // Then handle network/validation errors and only show success on 2xx.

    form.classList.add('hidden');
    success?.classList.remove('hidden');
    // Move focus to the confirmation for screen-reader and keyboard users.
    success?.focus();
  });

  resetBtn?.addEventListener('click', () => {
    form?.reset();
    success?.classList.add('hidden');
    form?.classList.remove('hidden');
    (form?.elements.namedItem('name') as HTMLInputElement | null)?.focus();
  });
</script>
