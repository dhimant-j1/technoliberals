<section class="section">
  <div class="shell">
    <div class="relative overflow-hidden rounded-4xl border border-line bg-panel/70 px-6 py-14 text-center sm:px-10 sm:py-20">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        aria-hidden="true"
        style="background: radial-gradient(36rem 18rem at 50% -20%, rgb(91 108 255 / 0.22), transparent 65%);"
      >
      </div>
      <div class="grid-overlay pointer-events-none absolute inset-0 -z-10 opacity-60" aria-hidden="true"></div>

      <h2 class="mx-auto max-w-3xl text-balance text-3xl leading-tight sm:text-[2.6rem]">
        Have a complex operation that should be simpler, faster, or smarter?
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-muted">
        Bring us the messy workflow, transaction flow, customer journey, or internal process. We
        will help turn it into a clear product roadmap and a buildable system.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="#contact" class="btn-primary">Book a Strategy Call</a>
        <a href="#contact" class="btn-secondary">Discuss an AI Use Case</a>
      </div>
    </div>
  </div>
</section>
