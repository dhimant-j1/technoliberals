---
const models = [
  {
    title: 'Paid Diagnostic Sprint',
    description: 'A short, focused engagement to map your operation and produce a costed roadmap.',
    bestFor: 'Teams that need clarity before committing budget.',
    outcomes: ['Process & systems map', 'Prioritised roadmap', 'Architecture & AI opportunities'],
  },
  {
    title: 'Fixed-Fee MVP Build',
    description: 'A defined scope, price, and timeline to get a working first version into users’ hands.',
    bestFor: 'Founders and business heads validating a new product.',
    outcomes: ['Shipped MVP', 'Core workflows live', 'A foundation built to scale'],
  },
  {
    title: 'Claude / AI Workflow Implementation',
    description: 'Identify, build, and integrate a Claude-powered workflow into your existing systems.',
    bestFor: 'Enterprises moving beyond AI experiments.',
    outcomes: ['Production AI workflow', 'Measured time saved', 'Secure system integration'],
  },
  {
    title: 'Product & Technology Office Retainer',
    description: 'Ongoing senior product and engineering leadership, billed monthly.',
    bestFor: 'Leadership teams that need consistent execution.',
    outcomes: ['Roadmap ownership', 'Delivery governance', 'Coordinated engineering'],
  },
  {
    title: 'Long-Term Engineering Partnership',
    description: 'A dedicated team building and evolving your platform over multiple quarters.',
    bestFor: 'Businesses scaling a core product.',
    outcomes: ['Continuous delivery', 'Reliability & scale', 'An evolving roadmap'],
  },
];
---

<section id="engagement" class="section">
  <div class="shell">
    <div class="max-w-2xl">
      <p class="eyebrow mb-5">Engagement models</p>
      <h2 class="text-3xl leading-tight sm:text-4xl">Flexible ways to work with us.</h2>
      <p class="mt-5 text-lg leading-relaxed text-muted">
        Start small to de-risk, or commit to a partnership — most clients move through these in
        sequence as confidence and scope grow.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        models.map((model) => (
          <article class="card card-hover flex flex-col p-6">
            <h3 class="text-lg font-semibold text-fg">{model.title}</h3>
            <p class="mt-2.5 text-sm leading-relaxed text-muted">{model.description}</p>

            <p class="mt-4 text-sm text-muted-2">
              <span class="font-semibold text-muted">Best for: </span>
              {model.bestFor}
            </p>

            <div class="mt-auto pt-5">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-muted-2">
                Example outcomes
              </p>
              <ul class="mt-3 flex flex-wrap gap-2">
                {model.outcomes.map((outcome) => (
                  <li class="chip">{outcome}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
